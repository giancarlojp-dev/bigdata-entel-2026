# Entorno virtual Python
venv/
__pycache__/
*.pyc
*.pyo

# Variables de entorno (contienen credenciales)
.env

# Datos crudos y procesados (volumen grande)
data/raw/osiptel/*.csv
data/raw/osiptel/*.xlsx
data/raw/synthetic/*.csv
data/raw/synthetic/*.json
data/processed/**/*.parquet

# Power BI
powerbi/*.pbix

# VS Code
.vscode/

# Sistema operativo
.DS_Store
Thumbs.db

# Logs de Airflow
airflow/logs/

# Archivos de Windows
desktop.ini

# Archivos de documentación compilados (si usas MkDocs o similares)
site/

# Notebooks sin limpiar (opcional, solo outputs)
.ipynb_checkpoints/

# Archivos grandes o comprimidos
*.zip
*.tar.gz
*.7z

# Metadatos locales de Spark
derby.log
metastore_db/
spark-warehouse/

# Base de datos local y logs de Airflow
airflow/airflow.db
# Metadata local de Airflow (SQLite)
airflow/airflow.db-journal
airflow/webserver_config.py
airflow/standalone_admin_password.txt